# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
RUST_LOG=info,backend=debug

# CORS Configuration
# Comma-separated list of allowed origins (e.g. http://localhost:3000,http://127.0.0.1:3000)
# In development, you can use * to allow any origin, but production requires explicit domains.
ALLOWED_ORIGINS=*

# Security Limits
SESSION_TIMEOUT_MINUTES=15
HEARTBEAT_TIMEOUT_SECONDS=60
MAX_MESSAGE_SIZE=65536
MAX_CONNECTIONS=1000

# TURN Server Configuration (Exposed to clients via /api/config)
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-username
TURN_PASSWORD=your-password
